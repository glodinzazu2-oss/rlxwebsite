{
  "name": "remolux-website",
  "version": "0.1.0",
  "private": true,
  "description": "Site vitrine premium REMOLUX — kit de feux LED de remorque sans fil",
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "check": "astro check",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "validate": "npm run check && npm run lint && npm run format:check && npm run build",
    "prepare": "husky"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.2.1",
    "@fontsource-variable/inter": "^5.1.0",
    "@fontsource-variable/space-grotesk": "^5.1.0",
    "astro": "^5.1.1",
    "gsap": "^3.12.5",
    "lenis": "^1.1.18"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "@eslint/js": "^9.17.0",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-astro": "^1.3.1",
    "husky": "^9.1.7",
    "lint-staged": "^15.3.0",
    "prettier": "^3.4.2",
    "prettier-plugin-astro": "^0.14.1",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.19.0"
  },
  "lint-staged": {
    "*.{ts,astro}": [
      "eslint --fix"
    ],
    "*.{ts,astro,css,json,md}": [
      "prettier --write"
    ]
  }
}
