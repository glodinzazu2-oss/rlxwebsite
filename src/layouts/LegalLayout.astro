---
/**
 * Gabarit des pages légales (mentions légales, confidentialité).
 * Pages secondaires : noindex (voir .claude/seo.md §3), ton sobre, prose lisible.
 */
import BaseLayout from './BaseLayout.astro';
import Header from '../components/global/Header.astro';
import Footer from '../components/global/Footer.astro';
import Button from '../components/ui/Button.astro';
import { getDictionary } from '../i18n';

interface Props {
  title: string;
  metaTitle: string;
  metaDescription: string;
}

const { title, metaTitle, metaDescription } = Astro.props;
const t = getDictionary();
---

<BaseLayout title={metaTitle} description={metaDescription} noindex>
  <Header />
  <main id="main" class="legal">
    <div class="container legal__inner">
      <header class="legal__header">
        <h1 class="legal__title">{title}</h1>
        <p class="legal__updated">
          {t.legalPages.lastUpdatedLabel}
          {t.legalPages.lastUpdated}
        </p>
      </header>

      <div class="legal__content">
        <slot />
      </div>

      <div class="legal__back">
        <Button href="/" variant="ghost">{t.legalPages.backHome}</Button>
      </div>
    </div>
  </main>
  <Footer />
</BaseLayout>

<style>
  .legal {
    padding-block: calc(76px + var(--space-16)) var(--space-24);
  }

  .legal__inner {
    max-width: 46rem;
  }

  .legal__header {
    margin-bottom: var(--space-12);
  }

  .legal__title {
    font-size: var(--text-3xl);
  }

  .legal__updated {
    margin-top: var(--space-3);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .legal__content {
    display: grid;
    gap: var(--space-8);
  }

  .legal__content :global(h2) {
    font-size: var(--text-xl);
    margin-bottom: var(--space-3);
  }

  .legal__content :global(p) {
    color: var(--color-text-secondary);
    max-width: 65ch;
  }

  .legal__content :global(dl) {
    display: grid;
    gap: var(--space-2);
  }

  .legal__content :global(dt) {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .legal__content :global(dd) {
    margin-bottom: var(--space-3);
    color: var(--color-text-secondary);
  }

  .legal__content :global(a) {
    color: var(--color-text);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .legal__back {
    margin-top: var(--space-16);
  }
</style>
