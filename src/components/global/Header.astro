---
import { getDictionary } from '../../i18n';
import { SITE } from '../../config/site';
import Button from '../ui/Button.astro';

const t = getDictionary();

const links = [
  { href: '#produit', label: t.nav.product },
  { href: '#technologie', label: t.nav.technology },
  { href: '#specs', label: t.nav.specs },
];
---

<header class="header" data-header>
  <div class="header__inner container container--wide">
    <a href="/" class="header__logo" aria-label={SITE.name}>
      REMOLUX<i class="header__led" aria-hidden="true"></i>
    </a>

    <nav class="header__nav" aria-label="Navigation principale">
      <ul role="list">
        {links.map((link) => (
          <li><a href={link.href} class="header__link">{link.label}</a></li>
        ))}
      </ul>
    </nav>

    <div class="header__cta">
      <Button href={SITE.amazonUrl} external>{t.nav.cta}</Button>
    </div>

    <button
      class="header__burger"
      data-menu-toggle
      aria-expanded="false"
      aria-controls="mobile-menu"
      aria-label={t.nav.menuOpen}
    >
      <span></span><span></span>
    </button>
  </div>

  <!-- Menu mobile plein écran -->
  <div class="menu" id="mobile-menu" data-menu>
    <nav aria-label="Navigation mobile">
      <ul role="list">
        {links.map((link) => (
          <li><a href={link.href} class="menu__link">{link.label}</a></li>
        ))}
        <li>
          <a href={SITE.amazonUrl} class="menu__link menu__link--cta" target="_blank" rel="noopener noreferrer">
            {t.nav.cta}
          </a>
        </li>
      </ul>
    </nav>
  </div>
</header>

<style>
  .header {
    position: fixed;
    inset-inline: 0;
    top: 0;
    z-index: var(--z-header);
    transition:
      background-color var(--duration-base) var(--ease-out-quart),
      border-color var(--duration-base) var(--ease-out-quart),
      backdrop-filter var(--duration-base) var(--ease-out-quart);
    border-bottom: 1px solid transparent;
  }

  .header.is-scrolled {
    background: rgba(6, 6, 7, 0.72);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-color: var(--color-border);
  }

  .header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-6);
    height: 76px;
  }

  .header__logo {
    position: relative;
    font-family: var(--font-display);
    font-weight: 700;
    letter-spacing: var(--tracking-caps);
    font-size: var(--text-base);
  }

  .header__led {
    position: absolute;
    left: 0;
    bottom: -6px;
    width: 100%;
    height: 2px;
    border-radius: var(--radius-full);
    background: var(--gradient-led);
    box-shadow: 0 0 10px rgba(255, 30, 45, 0.7);
    transform: scaleX(0.35);
    transform-origin: left center;
    transition: transform var(--duration-base) var(--ease-out-expo);
  }

  .header__logo:hover .header__led {
    transform: scaleX(1);
  }

  .header__nav ul {
    display: flex;
    gap: var(--space-8);
  }

  .header__link {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    transition: color var(--duration-fast) var(--ease-out-quart);
  }

  .header__link:hover {
    color: var(--color-text);
  }

  /* Burger */
  .header__burger {
    display: none;
    flex-direction: column;
    gap: 6px;
    padding: var(--space-2);
  }

  .header__burger span {
    width: 24px;
    height: 2px;
    background: var(--color-text);
    border-radius: var(--radius-full);
    transition: transform var(--duration-fast) var(--ease-out-quart), opacity var(--duration-fast);
  }

  .header__burger[aria-expanded='true'] span:first-child {
    transform: translateY(4px) rotate(45deg);
  }

  .header__burger[aria-expanded='true'] span:last-child {
    transform: translateY(-4px) rotate(-45deg);
  }

  /* Menu mobile */
  .menu {
    position: fixed;
    inset: 0;
    z-index: -1;
    display: grid;
    place-items: center;
    background: rgba(6, 6, 7, 0.96);
    backdrop-filter: blur(20px);
    opacity: 0;
    visibility: hidden;
    transition: opacity var(--duration-base) var(--ease-out-quart), visibility var(--duration-base);
  }

  .menu.is-open {
    opacity: 1;
    visibility: visible;
  }

  .menu ul {
    display: grid;
    gap: var(--space-8);
    text-align: center;
  }

  .menu__link {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: 600;
  }

  .menu__link--cta {
    color: var(--color-led-red);
  }

  @media (max-width: 820px) {
    .header__nav,
    .header__cta {
      display: none;
    }
    .header__burger {
      display: flex;
    }
  }
</style>

<style is:global>
  /* Verrouillage du scroll quand le menu mobile est ouvert */
  html.menu-open,
  html.menu-open body {
    overflow: hidden;
  }
</style>
