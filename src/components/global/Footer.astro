---
import { getDictionary } from '../../i18n';
import { SITE } from '../../config/site';

const t = getDictionary();
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer__inner">
    <div class="footer__brand">
      <p class="footer__logo">REMOLUX</p>
      <p class="footer__tagline">{t.footer.tagline}</p>
    </div>

    <nav class="footer__nav" aria-label={t.footer.navTitle}>
      <p class="footer__heading">{t.footer.navTitle}</p>
      <ul role="list">
        <li><a href="#produit">{t.nav.product}</a></li>
        <li><a href="#technologie">{t.nav.technology}</a></li>
        <li><a href="#specs">{t.nav.specs}</a></li>
      </ul>
    </nav>

    <nav class="footer__nav" aria-label={t.footer.legalTitle}>
      <p class="footer__heading">{t.footer.legalTitle}</p>
      <ul role="list">
        <li><a href="/mentions-legales">{t.footer.legal.mentions}</a></li>
        <li><a href="/confidentialite">{t.footer.legal.privacy}</a></li>
        <li><a href={`mailto:${SITE.email}`}>{t.footer.legal.contact}</a></li>
      </ul>
    </nav>
  </div>

  <div class="container footer__bottom">
    <p>© {year} {t.footer.copyright}</p>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--color-border);
    padding-block: var(--space-16) var(--space-8);
    background: var(--color-bg-elevated);
  }

  .footer__inner {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: var(--space-12);
  }

  .footer__logo {
    font-family: var(--font-display);
    font-weight: 700;
    letter-spacing: var(--tracking-caps);
  }

  .footer__tagline {
    margin-top: var(--space-2);
    color: var(--color-text-muted);
    font-size: var(--text-sm);
  }

  .footer__heading {
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-bottom: var(--space-4);
  }

  .footer__nav ul {
    display: grid;
    gap: var(--space-3);
  }

  .footer__nav a {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    transition: color var(--duration-fast) var(--ease-out-quart);
  }

  .footer__nav a:hover {
    color: var(--color-text);
  }

  .footer__bottom {
    margin-top: var(--space-12);
    padding-top: var(--space-6);
    border-top: 1px solid var(--color-border);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }

  @media (max-width: 640px) {
    .footer__inner {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }
  }
</style>
