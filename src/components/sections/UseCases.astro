---
import { Picture } from 'astro:assets';
import { getDictionary } from '../../i18n';
import SectionHeading from '../ui/SectionHeading.astro';
import nautisme from '../../assets/images/situation-nautisme-port-crepuscule.png';
import caravaning from '../../assets/images/situation-caravane-route-soleil.png';
import agricole from '../../assets/images/situation-agricole-champ-boue.png';
import btp from '../../assets/images/situation-btp-porte-engins.png';
import kitReel from '../../assets/images/kit-reel-conditions.png';

const t = getDictionary();

const images = { nautisme, caravaning, agricole, btp } as const;
const items = t.useCases.items.map((item) => ({ ...item, image: images[item.key] }));

/**
 * Points d'allumage LED par scène (coordonnées en % de l'image, sur chaque feu).
 * Prototype : agricole uniquement — placement à valider sur preview avant
 * d'étendre aux autres univers (voir src/scripts/animations/ignite.ts).
 */
const ignitePoints: Partial<Record<(typeof items)[number]['key'], { x: number; y: number }[]>> = {
  agricole: [
    { x: 57, y: 57 },
    { x: 83, y: 57 },
  ],
};
---

<section class="section usages" aria-labelledby="usages-title">
  <div class="container">
    <SectionHeading eyebrow={t.useCases.eyebrow} title={t.useCases.title} titleId="usages-title" />

    <ul class="usages__grid" role="list">
      {
        items.map((item, i) => (
          <li class="usages__card" data-reveal data-reveal-delay={String(0.06 * (i % 2))}>
            <div
              class="usages__media"
              data-tilt
              data-ignite-group={ignitePoints[item.key] ? '' : null}
            >
              <Picture
                src={item.image}
                formats={['avif', 'webp']}
                widths={[480, 760, 1200]}
                sizes="(min-width: 900px) 46vw, 92vw"
                alt={item.alt}
                loading="lazy"
              />
              {(ignitePoints[item.key] ?? []).map((pt) => (
                <span
                  class="ignite"
                  style={`--x: ${pt.x}%; --y: ${pt.y}%;`}
                  data-ignite
                  aria-hidden="true"
                />
              ))}
            </div>
            <h3 class="usages__title">{item.title}</h3>
            <p class="usages__desc">{item.description}</p>
          </li>
        ))
      }
    </ul>

    <p class="usages__disclaimer">{t.useCases.disclaimer}</p>

    <figure class="usages__real" data-reveal>
      <div class="usages__real-media" data-tilt>
        <Picture
          src={kitReel}
          formats={['avif', 'webp']}
          widths={[480, 705]}
          sizes="(min-width: 900px) 440px, 88vw"
          alt={t.useCases.realPhoto.alt}
          loading="lazy"
        />
      </div>
      <figcaption class="usages__real-text">
        <h3 class="usages__real-title">{t.useCases.realPhoto.title}</h3>
        <p class="usages__real-caption">{t.useCases.realPhoto.caption}</p>
      </figcaption>
    </figure>
  </div>
</section>

<style>
  .usages {
    background:
      radial-gradient(38% 46% at 12% 8%, rgba(255, 30, 45, 0.05), transparent 70%), var(--color-bg);
  }

  .usages__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(380px, 100%), 1fr));
    gap: var(--space-6);
  }

  .usages__card {
    display: grid;
    gap: var(--space-2);
  }

  .usages__media {
    border-radius: var(--radius-md);
    overflow: clip;
    border: 1px solid var(--color-border);
    background: var(--color-bg-elevated);
    aspect-ratio: 4 / 3;
    margin-bottom: var(--space-2);
  }

  .usages__media :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--duration-slow) var(--ease-out-quart);
  }

  /* Halo d'allumage LED, posé sur chaque feu de la scène (voir ignite.ts).
     mix-blend-mode: screen → la lumière s'ajoute à la photo au lieu de la masquer. */
  .ignite {
    position: absolute;
    left: var(--x);
    top: var(--y);
    width: 17%;
    aspect-ratio: 1;
    translate: -50% -50%;
    border-radius: var(--radius-full);
    background: radial-gradient(
      circle,
      rgba(255, 30, 45, 0.75) 0%,
      rgba(255, 30, 45, 0.28) 42%,
      transparent 70%
    );
    mix-blend-mode: screen;
    pointer-events: none;
    opacity: 0;
    will-change: opacity, transform;
  }

  @media (hover: hover) and (prefers-reduced-motion: no-preference) {
    .usages__card:hover .usages__media :global(img) {
      transform: scale(1.04);
    }
  }

  .usages__title {
    font-size: var(--text-lg);
  }

  .usages__desc {
    color: var(--color-text-secondary);
    font-size: var(--text-sm);
    max-width: 48ch;
  }

  .usages__disclaimer {
    margin-top: var(--space-6);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }

  /* --- Photo réelle, sans mise en scène --- */
  .usages__real {
    margin-top: var(--space-16);
    display: grid;
    grid-template-columns: minmax(0, 440px) 1fr;
    gap: var(--space-8);
    align-items: center;
    padding: var(--space-8);
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-border);
    background: var(--color-bg-elevated);
  }

  .usages__real-media {
    border-radius: var(--radius-md);
    overflow: clip;
  }

  .usages__real-media :global(img) {
    width: 100%;
    height: auto;
  }

  .usages__real-title {
    font-size: var(--text-xl);
    margin-bottom: var(--space-3);
  }

  .usages__real-caption {
    color: var(--color-text-secondary);
    font-size: var(--text-sm);
    max-width: 44ch;
  }

  @media (max-width: 820px) {
    .usages__real {
      grid-template-columns: 1fr;
      padding: var(--space-6);
    }
  }
</style>
